{"id": "tool-001", "name": "basic_tool_call", "description": "Model correctly calls a simple tool", "input": {"messages": [{"role": "user", "content": "What is the weather in Paris?"}], "tools": [{"type": "function", "function": {"name": "get_weather", "description": "Get weather for a location", "parameters": {"type": "object", "properties": {"location": {"type": "string"}}, "required": ["location"]}}}]}, "expected": {"has_tool_call": true, "tool_name": "get_weather", "tool_args_has": "location"}, "providers": ["openai", "claude"]}
{"id": "tool-002", "name": "tool_result_continuation", "description": "Model continues after tool result", "input": {"messages": [{"role": "user", "content": "What is the weather in Paris?"}, {"role": "assistant", "content": null, "tool_calls": [{"id": "call_1", "type": "function", "function": {"name": "get_weather", "arguments": "{\"location\": \"Paris\"}"}}]}, {"role": "tool", "content": "Sunny, 22°C", "tool_call_id": "call_1"}]}, "expected": {"role": "assistant", "content_pattern": "(?i)(sunny|22|paris)"}, "providers": ["openai", "claude"]}
{"id": "tool-003", "name": "multiple_tools_available", "description": "Model selects appropriate tool from multiple options", "input": {"messages": [{"role": "user", "content": "What time is it in Tokyo?"}], "tools": [{"type": "function", "function": {"name": "get_weather", "description": "Get weather for a location", "parameters": {"type": "object", "properties": {"location": {"type": "string"}}}}}, {"type": "function", "function": {"name": "get_time", "description": "Get current time for a timezone", "parameters": {"type": "object", "properties": {"timezone": {"type": "string"}}}}}]}, "expected": {"has_tool_call": true, "tool_name": "get_time"}, "providers": ["openai", "claude"]}
{"id": "tool-004", "name": "tool_choice_auto", "description": "Model decides whether to use tool with tool_choice auto", "input": {"messages": [{"role": "user", "content": "What is 2+2?"}], "tools": [{"type": "function", "function": {"name": "calculator", "description": "Perform calculations", "parameters": {"type": "object", "properties": {"expression": {"type": "string"}}}}}], "tool_choice": "auto"}, "expected": {"may_have_tool_call": true, "content_pattern": "4"}, "providers": ["openai", "claude"]}
{"id": "tool-005", "name": "tool_choice_required", "description": "Model must use a tool with tool_choice required", "input": {"messages": [{"role": "user", "content": "Hello"}], "tools": [{"type": "function", "function": {"name": "greet", "description": "Generate a greeting", "parameters": {"type": "object", "properties": {"name": {"type": "string"}}}}}], "tool_choice": "required"}, "expected": {"has_tool_call": true}, "providers": ["openai", "claude"]}
