{"id": "stream-001", "name": "basic_streaming", "description": "Basic streaming returns multiple chunks", "input": {"messages": [{"role": "user", "content": "Count from 1 to 5"}], "stream": true}, "expected": {"min_chunks": 3, "final_has_finish_reason": true}, "providers": ["openai", "claude", "ollama"]}
{"id": "stream-002", "name": "streaming_content_matches_non_streaming", "description": "Concatenated stream matches non-streaming response", "input": {"messages": [{"role": "user", "content": "What is the capital of France?"}], "stream": true, "temperature": 0}, "expected": {"content_equals_non_streaming": true}, "providers": ["openai", "claude"]}
{"id": "stream-003", "name": "streaming_finish_reason", "description": "Streaming ends with proper finish reason", "input": {"messages": [{"role": "user", "content": "Say hi"}], "stream": true}, "expected": {"finish_reason": "stop"}, "providers": ["openai", "claude", "ollama"]}
{"id": "stream-004", "name": "streaming_with_max_tokens", "description": "Streaming respects max_tokens and returns length finish_reason", "input": {"messages": [{"role": "user", "content": "Write a very long story"}], "stream": true, "max_tokens": 10}, "expected": {"finish_reason": "length", "max_total_tokens": 15}, "providers": ["openai", "claude"]}
{"id": "stream-005", "name": "streaming_token_usage", "description": "Streaming includes token usage in final chunk", "input": {"messages": [{"role": "user", "content": "Hello"}], "stream": true, "stream_options": {"include_usage": true}}, "expected": {"final_has_usage": true, "usage_has_prompt_tokens": true, "usage_has_completion_tokens": true}, "providers": ["openai", "claude"]}
