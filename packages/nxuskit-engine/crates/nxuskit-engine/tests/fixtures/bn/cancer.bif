// Bayesian Network: Cancer
// 5 variables, 4 edges
// Simple cancer diagnosis network

network unknown {
}

variable Pollution {
  type discrete [ 2 ] { high, low };
}

variable Smoker {
  type discrete [ 2 ] { true, false };
}

variable Cancer {
  type discrete [ 2 ] { true, false };
}

variable Xray {
  type discrete [ 2 ] { positive, negative };
}

variable Dyspnea {
  type discrete [ 2 ] { true, false };
}

probability ( Pollution ) {
  table 0.9, 0.1;
}

probability ( Smoker ) {
  table 0.3, 0.7;
}

probability ( Cancer | Pollution, Smoker ) {
  (high, true)  0.05, 0.95;
  (high, false) 0.02, 0.98;
  (low,  true)  0.03, 0.97;
  (low,  false) 0.001, 0.999;
}

probability ( Xray | Cancer ) {
  (true)  0.90, 0.10;
  (false) 0.20, 0.80;
}

probability ( Dyspnea | Cancer ) {
  (true)  0.65, 0.35;
  (false) 0.30, 0.70;
}
